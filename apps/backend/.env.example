# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001
FRONTEND_URL=http://localhost:3000

# ─── Database ─────────────────────────────────────────────────────────────────
# Local (Docker): postgresql://lalabits:lalabits@localhost:5432/lalabits
# Production: use a managed PostgreSQL connection string with SSL
DATABASE_URL=postgresql://lalabits:lalabits@localhost:5432/lalabits

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local (Docker): redis://localhost:6379
# Production: use a managed Redis connection string (with auth if required)
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: openssl rand -hex 64
JWT_SECRET=
JWT_ACCESS_TOKEN_TTL=900        # seconds — 15 minutes
JWT_REFRESH_TOKEN_TTL=2592000   # seconds — 30 days

# ─── Object Storage (S3-compatible) ───────────────────────────────────────────
# Local (MinIO via Docker):
#   STORAGE_ENDPOINT=http://localhost:9000
#   STORAGE_REGION=us-east-1
#   STORAGE_BUCKET=lalabits
#   STORAGE_ACCESS_KEY_ID=lalabits
#   STORAGE_SECRET_ACCESS_KEY=lalabits123
# Production: replace with real S3 / Cloudflare R2 / Backblaze B2 values
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=us-east-1
STORAGE_BUCKET=lalabits
STORAGE_ACCESS_KEY_ID=lalabits
STORAGE_SECRET_ACCESS_KEY=lalabits123

# ─── Email ────────────────────────────────────────────────────────────────────
# Local (Mailpit SMTP via Docker):
#   EMAIL_PROVIDER=smtp
#   EMAIL_SMTP_HOST=localhost
#   EMAIL_SMTP_PORT=1025
#   (no credentials needed for Mailpit)
#   Emails are NOT delivered — they are caught in the Mailpit web UI at http://localhost:8025
# Production: switch to EMAIL_PROVIDER=resend and set EMAIL_API_KEY
EMAIL_PROVIDER=smtp
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_API_KEY=             # Only needed when EMAIL_PROVIDER=resend
EMAIL_FROM_ADDRESS=noreply@lalabits.art
EMAIL_FROM_NAME=lalabits.art

# ─── IBAN Encryption ──────────────────────────────────────────────────────────
# AES-256-GCM key used to encrypt creator IBAN at rest in CreatorApplication.
# Generate locally: openssl rand -hex 32
# NEVER commit the real value. NEVER log or expose this key anywhere.
IBAN_ENCRYPTION_KEY=

# ─── Payment Gateway (iyzico) ─────────────────────────────────────────────────
# Sandbox (local/staging): https://sandbox.iyzipay.com
# Production:              https://api.iyzipay.com
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox.iyzipay.com
# Shared secret for HMAC-SHA256 webhook signature verification
IYZICO_WEBHOOK_SECRET=
# Set to true to enable real İyzico payment calls; false = mock path (local dev)
PAYMENT_ENABLED=false
# Callback URLs — must be publicly reachable (use ngrok for sandbox local testing)
CHECKOUT_CALLBACK_URL=http://localhost:3001/checkout/callback
MEMBERSHIP_CALLBACK_URL=http://localhost:3001/membership/callback

# ─── Platform Config ──────────────────────────────────────────────────────────
PLATFORM_FEE_PERCENT=0.10
GRACE_PERIOD_DAYS=7
STALE_ORDER_TIMEOUT_MINUTES=30
